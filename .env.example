# CVE 漏洞监控系统 - 环境配置
# 架构：SQLite + WSL Redis + GPU 加速（可选）

# ==================== Redis 配置（WSL）====================
# WSL Redis 连接配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis 连接提示：
# - WSL2 Redis 可通过 localhost 访问
# - 如需密码，请在 WSL 中配置 Redis 并填写上方密码
# - 检查 Redis 状态：wsl redis-cli ping

# ==================== SQLite 配置 ====================
# SQLite 数据库文件路径（相对于项目根目录）
SQLITE_DB_PATH=cve_data/cve_database.db

# SQLite 性能优化选项
SQLITE_WAL_MODE=1              # 启用 WAL 模式（提升并发性能）
SQLITE_CACHE_SIZE=10000        # 缓存大小（页数）
SQLITE_SYNCHRONOUS=NORMAL      # 同步模式：NORMAL（平衡性能和安全）
SQLITE_TEMP_STORE=MEMORY       # 临时数据存储在内存

# ==================== GPU 加速配置（可选）====================
# GPU 向量搜索功能（需要 Ollama + PostgreSQL/pgvector）
ENABLE_GPU_FEATURES=0          # 0=禁用, 1=启用

# Ollama 配置（用于 LLM 和向量生成）
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=nomic-embed-text  # 向量模型

# PostgreSQL 向量数据库（仅 GPU 功能启用时需要）
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=defaultpassword
POSTGRES_DB=cve_vectors

# ==================== NVD API 配置 ====================
# NVD API Key（可选，提升请求速率）
# 申请地址：https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ==================== 应用配置 ====================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 数据目录
DATA_DIR=cve_data

# 是否启用自动备份
ENABLE_AUTO_BACKUP=1
