# CVE 漏洞监控系统 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ==================== NVD API 配置 ====================
# 申请地址: https://nvd.nist.gov/developers/request-an-api-key
# 免费申请，提升采集速度 10 倍
NVD_API_KEY=your_nvd_api_key_here

# ==================== Redis 配置 ====================
# Redis 服务器地址
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码（建议修改默认密码）
REDIS_PASSWORD=defaultpassword

# Redis 数据库编号（0-15）
REDIS_DB=0

# ==================== 数据存储配置 ====================
# 数据存储目录
DATA_DIR=cve_data

# SQLite 数据库文件名
SQLITE_DB=cve_database.db

# ==================== 采集配置 ====================
# 默认采集时间范围（天数）
DEFAULT_DAYS=30

# 并发请求数（有 API Key 时可设置更大）
CONCURRENT_REQUESTS=5

# 请求超时时间（秒）
REQUEST_TIMEOUT=30

# ==================== GUI 配置 ====================
# 窗口宽度
WINDOW_WIDTH=1400

# 窗口高度
WINDOW_HEIGHT=900

# 关联数据最大显示数量
MAX_DISPLAY_ITEMS=1000

# ==================== 日志配置 ====================
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=cve_monitor.log

# ==================== 性能优化 ====================
# Redis Pipeline 批量大小
REDIS_PIPELINE_SIZE=1000

# SQLite 备份队列大小
BACKUP_QUEUE_SIZE=10000

# GUI 更新间隔（毫秒）
GUI_UPDATE_INTERVAL=100
