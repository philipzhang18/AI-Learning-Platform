# 智能知识管理平台 - 环境配置
# 架构：SQLite + WSL Redis（可选）

# ==================== AI 模型配置 ====================
# Qwen / 阿里云百炼（费曼学习、新闻简报、播客脚本等）
QWEN_API_KEY=
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.6-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Claude API（AI 安全分析）
CLAUDE_API_KEY=

# Exa API（网页搜索与抓取）
EXA_API_KEY=

# ==================== NVD API 配置 ====================
# NVD API Key（可选，提升请求速率）
# 申请地址：https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ==================== Redis 配置（WSL，可选）====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== SQLite 配置 ====================
SQLITE_DB_PATH=cve_data/cve_database.db
SQLITE_WAL_MODE=1
SQLITE_CACHE_SIZE=10000
SQLITE_SYNCHRONOUS=NORMAL
SQLITE_TEMP_STORE=MEMORY

# ==================== 应用配置 ====================
LOG_LEVEL=INFO
DATA_DIR=cve_data
ENABLE_AUTO_BACKUP=1
