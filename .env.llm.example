# LLM API 环境变量配置示例
# 复制此文件为 .env 并填入您的实际 API 密钥

# Claude API 配置
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-3-opus-20240229

# Qwen API 配置（阿里云百炼）
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-coder-plus

# 系统配置
DEFAULT_MODEL_PROVIDER=claude
AUTO_FALLBACK=true
TIMEOUT_SECONDS=30
MAX_RETRIES=3

# 注意：
# 1. 请勿将包含真实 API Key 的 .env 文件提交到版本控制
# 2. 在 .gitignore 中添加 .env 以防止意外提交
# 3. Qwen 模型选项：qwen-turbo, qwen-plus, qwen-max, qwen-coder-plus
# 4. Claude 模型选项：claude-3-opus-20240229, claude-3-sonnet-20240229