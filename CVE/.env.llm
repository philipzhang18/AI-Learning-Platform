# Qwen API 配置 (阿里云百炼)
# 请将下方的 sk-your-qwen-api-key-here 替换为你的实际 API Key

# 主要配置项 - 必填
DASHSCOPE_API_KEY=sk-22ec825cb9cf4ad9acd33f151845f201
QWEN_API_KEY=sk-22ec825cb9cf4ad9acd33f151845f201

# API 端点配置 - 一般无需修改
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型配置 - 可选修改
# 可选模型: qwen-turbo, qwen-plus, qwen-max, qwen-coder-plus, qwen3-coder-plus
QWEN_MODEL=qwen3-coder-plus

# 系统配置 - 可选修改
DEFAULT_MODEL_PROVIDER=qwen
AUTO_FALLBACK=true
TIMEOUT_SECONDS=30
MAX_RETRIES=3
RETRY_DELAY=2

# 注意事项:
# 1. 请将 sk-your-qwen-api-key-here 替换为你的实际 API Key
# 2. 不要将此文件提交到版本控制系统
# 3. 确保 .gitignore 中包含 .env.llm
# 4. 获取 API Key: https://dashscope.console.aliyun.com/
