# CVE 监控系统环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== 数据库配置 ====================
# MongoDB 配置
MONGO_PASSWORD=your_secure_mongodb_password_here
MONGO_DATABASE=cve_monitor

# Redis 配置
REDIS_PASSWORD=your_secure_redis_password_here

# ==================== API 密钥 ====================
# NVD API Key (可选但推荐)
# 申请地址: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# CNVD API Key (可选)
CNVD_API_KEY=

# GitHub Token (用于访问 GitHub Security Advisory)
GITHUB_TOKEN=

# ==================== 应用配置 ====================
# 应用密钥 (用于 JWT 等加密)
SECRET_KEY=your-very-long-random-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# 应用环境
ENVIRONMENT=development  # development, staging, production

# ==================== 邮件配置 ====================
# SMTP 服务器配置 (用于发送告警邮件)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=CVE Monitor <alerts@example.com>

# ==================== 通知配置 ====================
# Slack Webhook URL (可选)
SLACK_WEBHOOK_URL=

# 企业微信 Webhook (可选)
WECHAT_WEBHOOK_URL=

# 钉钉 Webhook (可选)
DINGTALK_WEBHOOK_URL=

# Telegram Bot Token (可选)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==================== 性能配置 ====================
# 并发配置
MAX_WORKERS=4
MAX_CONNECTIONS=100

# 缓存配置
CACHE_TTL=3600  # 缓存过期时间（秒）

# ==================== 日志配置 ====================
# 日志级别
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Sentry DSN (用于错误追踪，可选)
SENTRY_DSN=

# ==================== 安全配置 ====================
# CORS 允许的源
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ==================== 采集配置 ====================
# 数据采集间隔（分钟）
COLLECT_INTERVAL=60

# 采集天数范围
COLLECT_DAYS_RANGE=7

# 是否启用自动采集
AUTO_COLLECT_ENABLED=true