[wsl2]
# WSL 2 优化配置文件
# 位置: C:\Users\<你的用户名>\.wslconfig

# ========================================
# 核心资源限制
# ========================================

# 限制 WSL 2 最大内存（建议：系统总内存的 50%）
# 示例：16GB 系统 → 8GB
memory=8GB

# 限制 WSL 2 CPU 核心数（建议：系统总核心数的 50%）
# 示例：4 核系统 → 2 核
processors=2

# 限制交换空间大小
swap=2GB

# ========================================
# 性能优化
# ========================================

# 关闭页面报告（减少内存占用）
pageReporting=false

# 限制虚拟机空闲超时（毫秒）
# 60000ms = 1分钟后释放资源
vmIdleTimeout=60000

# ========================================
# 高级选项（可选）
# ========================================

# 关闭嵌套虚拟化（如果不需要 Docker-in-Docker）
nestedVirtualization=false

# 设置本地主机转发（保持默认）
localhostForwarding=true

# ========================================
# 网络配置
# ========================================

# 网络模式（默认 NAT）
# networkingMode=NAT

# DNS 隧道（保持默认）
# dnsTunneling=true

# ========================================
# 内核配置
# ========================================

# 自定义 Linux 内核路径（可选）
# kernel=C:\\Users\\<username>\\bzImage

# 内核命令行参数（可选）
# kernelCommandLine=vsyscall=emulate

# ========================================
# 调试选项
# ========================================

# 启用控制台日志（调试用）
# debugConsole=true

# ========================================
# 说明
# ========================================
#
# 1. 修改此文件后，需要完全关闭 WSL 2:
#    wsl --shutdown
#
# 2. 然后重启 Docker Desktop
#
# 3. 验证配置生效:
#    wsl -l -v
#    docker info
#
# 4. 监控资源使用:
#    - Windows 任务管理器 → 查看 "Vmmem" 进程
#    - PowerShell: Get-Process -Name vmmem
#
# ========================================
# 性能预期
# ========================================
#
# 优化前:
#   - WSL 2 内存: 8-15GB
#   - WSL 2 CPU: 高占用 (>50%)
#   - Docker Desktop: 高占用
#
# 优化后:
#   - WSL 2 内存: 4-8GB (降低 50%)
#   - WSL 2 CPU: 低占用 (<30%)
#   - Docker Desktop: 低占用 (降低 40-60%)
#
# ========================================
